# Backend URL (no trailing slash)
BACKEND_URL=https://jama-crm-prod-production.up.railway.app

# Shared secret between ingest service <-> backend (MUST match ZALO_INGEST_SECRET in backend)
ZALO_INGEST_SECRET=your-secret-here

# Poll interval for login requests in milliseconds (default: 10000)
POLL_MS=10000

# Heartbeat interval in milliseconds (default: 60000)
HEARTBEAT_MS=60000

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info
