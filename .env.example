# === JAMA HOME CRM Configuration ===

# Database
DATABASE_URL=postgresql+asyncpg://jama:jama_secret_2026@postgres:5432/jama_crm
DATABASE_URL_SYNC=postgresql://jama:jama_secret_2026@postgres:5432/jama_crm

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=

# API
API_BASE_URL=http://backend:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# LLM (LiteLLM compatible)
LLM_PROVIDER=groq
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=your-groq-api-key
LLM_FALLBACK_MODEL=ollama/llama3.2

# ERP Sync
ERP_BASE_URL=https://jama.lightning-labs.io
ERP_API_KEY=
ERP_SYNC_ENABLED=false

# File Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jama-crm

# App
APP_NAME=JAMA HOME CRM
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
TIMEZONE=Asia/Ho_Chi_Minh
